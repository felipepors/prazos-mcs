# alvara-notifier — template de variáveis de ambiente
# Copie para `.env` (que está no .gitignore) e preencha. NUNCA commite o .env preenchido.
# Em produção, estes valores vão para os Supabase secrets, não para o Git.

# --- Anthropic (extração de alvará via claude-haiku-4-5) ---
ANTHROPIC_API_KEY=

# --- SMTP Locaweb (envio do e-mail — só usado na aprovação) ---
# Host: email-ssl.com.br | Porta 465 (SSL) ou 587 (STARTTLS)
# O usuário/remetente é o e-mail institucional completo:
LOCAWEB_SMTP_USER=contato@martinscorreadasilva.com.br
LOCAWEB_SMTP_PASS=

# --- Supabase (referência do projeto existente MCS-Prazos) ---
# Necessário só para scripts/Edge Functions que falem com o projeto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
